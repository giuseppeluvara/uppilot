# ==========================================================================
# UPPilot — variabili d'ambiente (copiare in `.env` e adattare)
# NB: i PESI dei modelli non stanno qui e non vanno in git: solo nomi/tag.
# ==========================================================================

# --- Django ---
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=cambiami-in-produzione
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend

# --- Database (Postgres + pgvector) ---
POSTGRES_DB=uppilot
POSTGRES_USER=uppilot
POSTGRES_PASSWORD=uppilot
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Redis / Celery ---
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# --- Servizi AI (sempre dietro le astrazioni in backend/ai/) ---
# Su Mac Apple Silicon Ollama gira sull'HOST (Metal): usare l'override mac.
OLLAMA_BASE_URL=http://host.docker.internal:11434
PRIVACY_FILTER_URL=http://privacy-filter:8000

# Backend LLM locale. I provider commerciali NON si abilitano globalmente:
# sono disponibili solo come opt-in esplicito per singola azione nella UI/API.
LLM_BACKEND=ollama

# Limite upload applicativo (default 50 MB).
UPPILOT_MAX_UPLOAD_BYTES=52428800

# Ricerca giuridica (§6): "stub" (default) | "web" (ricerca web generica).
# La query esce sempre pseudonimizzata.
LEGAL_SEARCH_BACKEND=stub

# Tag/versione modelli (i pesi si scaricano con scripts/provision_models.sh)
OCR_MODEL=glm-ocr:latest
LLM_MODEL=qwen3:8b
EMBEDDING_MODEL=nomic-embed-text
PRIVACY_FILTER_MODEL=openai/privacy-filter

# --- LLM commerciale (OPT-IN, §5 — non attivo di default) ---
# COMMERCIAL_LLM_PROVIDER=anthropic
# COMMERCIAL_LLM_API_KEY=
# COMMERCIAL_LLM_MODEL=claude-opus-4-8
